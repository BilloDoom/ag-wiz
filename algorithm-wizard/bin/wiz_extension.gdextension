[configuration]
entry_symbol = "wiz_extension_init"
compatibility_minimum = 4.5

[libraries]
windows.debug.x86_64 = "res://bin/Debug/wiz_extension.dll"
windows.release.x86_64 = "res://bin/Release/wiz_extension.dll"
linux.debug.x86_64 = "res://bin/Debug/libwiz_extension.so"
linux.release.x86_64 = "res://bin/Release/libwiz_extension.so"
macos.debug = "res://bin/Debug/libwiz_extension.dylib"
macos.release = "res://bin/Release/libwiz_extension.dylib"
